{
  "expo": {
    "name": "PantryPilot",
    "slug": "pantrypilot",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "backgroundColor": "#F7F7F1",
    "icon": "./assets/icon.png",
    "plugins": [
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow PantryPilot to use your camera to scan your kitchen.",
          "photosPermission": "Allow PantryPilot to access photos or a walkthrough video of your kitchen.",
          "microphonePermission": false
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow PantryPilot to show nearby stores only when a recipe needs one or two items."
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/app-check",
      "expo-status-bar",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#2F5B48",
          "image": "./assets/splash.png",
          "imageWidth": 220,
          "resizeMode": "contain"
        }
      ],
      "expo-font"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pantrypilot.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.pantrypilot.app",
      "googleServicesFile": "./google-services.json",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F7F7F1"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "7154888d-b589-4c77-9b24-c1221f71b9f3"
      }
    },
    "owner": "shreyan14"
  }
}
