# Cloud Run receives credentials from Secret Manager, never from this file.
OPENAI_MODEL=gpt-5.6
OPENAI_TIMEOUT_SECONDS=300

# Cloud Run accepts a maximum 32 MiB HTTP/1 request. These values reserve
# headroom for multipart boundaries while allowing one video or four photos.
MAX_UPLOAD_MB=28
MAX_IMAGE_UPLOAD_MB=7
MAX_IMAGES=4
MAX_VIDEO_SECONDS=35
MAX_FRAMES=8

SERPAPI_SEARCH_URL=https://serpapi.com/search.json
SERPAPI_COUNTRY=us
SERPAPI_LANGUAGE=en
GOOGLE_PLACES_SEARCH_URL=https://places.googleapis.com/v1/places:searchNearby

RECIPE_IMAGE_MODEL=gpt-image-2
RECIPE_IMAGE_SIZE=816x816
RECIPE_IMAGE_TIMEOUT_SECONDS=35

# Native clients do not use CORS. The generated run.app hostname is not known
# until the first deployment, so host validation remains unrestricted here.
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006
ALLOWED_HOSTS=*
