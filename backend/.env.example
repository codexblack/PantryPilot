# OpenAI is optional only when exercising the local demo flow.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
OPENAI_TIMEOUT_SECONDS=300

# Upload and frame-processing limits.
MAX_UPLOAD_MB=28
MAX_IMAGE_UPLOAD_MB=7
MAX_IMAGES=4
MAX_VIDEO_SECONDS=35
MAX_FRAMES=8

# SerpAPI Google Shopping. Leave the key empty to disable priced offers.
SERPAPI_API_KEY=
SERPAPI_SEARCH_URL=https://serpapi.com/search.json
SERPAPI_COUNTRY=us
SERPAPI_LANGUAGE=en

# Google Maps is only used for location-only fallback results.
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_SEARCH_URL=https://places.googleapis.com/v1/places:searchNearby

# Recipe image generation uses the same OpenAI API key.
RECIPE_IMAGE_MODEL=gpt-image-2
RECIPE_IMAGE_SIZE=816x816
RECIPE_IMAGE_TIMEOUT_SECONDS=35

# Browser CORS and HTTP Host validation. Native clients do not use CORS.
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006
ALLOWED_HOSTS=*

# Firebase App Check is disabled locally. Cloud Run enables it only after both
# registered PantryPilot app IDs can produce valid Android and iOS attestations.
APP_CHECK_ENFORCED=false
APP_CHECK_PROJECT_ID=
APP_CHECK_ALLOWED_APP_IDS=
